@page "/devices"
<PageTitle>Devices — Horizon SimTool</PageTitle>

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-track-bright tracking-tight">Devices</h1>
        <p class="text-sm text-track-muted mt-1">Connected controllers and peripherals</p>
    </div>
    <button class="flex items-center gap-2 px-4 py-2 bg-racing-orange hover:bg-racing-orange/90 text-white text-sm font-semibold rounded-lg transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
        </svg>
        Refresh
    </button>
</div>

<!-- Device table -->
<div class="bg-track-card border border-track-border rounded-xl overflow-hidden">
    <div class="px-4 py-3 border-b border-track-border flex items-center gap-2">
        <span class="inline-block w-2 h-2 rounded-full bg-track-border"></span>
        <span class="text-xs text-track-muted font-mono">No devices detected — connect your wheel and refresh</span>
    </div>
    <table class="w-full text-sm">
        <thead>
            <tr class="border-b border-track-border">
                <th class="text-left px-4 py-3 text-xs font-semibold text-track-muted uppercase tracking-wider">Device Name</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-track-muted uppercase tracking-wider">VID/PID</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-track-muted uppercase tracking-wider">Axes</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-track-muted uppercase tracking-wider">Buttons</th>
                <th class="text-left px-4 py-3 text-xs font-semibold text-track-muted uppercase tracking-wider">Role</th>
                <th class="px-4 py-3"></th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td colspan="6" class="px-4 py-8 text-center text-track-muted text-sm">
                    No game controllers found. Connect your wheel base and pedals, then refresh.
                </td>
            </tr>
        </tbody>
    </table>
</div>
