@page "/"
<PageTitle>Dashboard — Horizon SimTool</PageTitle>

<!-- Page heading -->
<div class="mb-8">
    <h1 class="text-2xl font-bold text-track-bright tracking-tight">Dashboard</h1>
    <p class="text-sm text-track-muted mt-1">Wheel mapping · FFB tuning · Device management · Built for sim racers</p>
</div>

<!-- Status cards -->
<div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-4 mb-8">
    <div class="bg-track-card border border-track-border rounded-xl p-4">
        <p class="text-xs text-track-muted uppercase tracking-wider mb-2">Game Install</p>
        <p class="text-sm font-semibold text-racing-green flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-racing-green inline-block"></span>
            Not detected
        </p>
        <p class="text-xs text-track-muted mt-1 font-mono truncate">Click Find to locate</p>
    </div>
    <div class="bg-track-card border border-track-border rounded-xl p-4">
        <p class="text-xs text-track-muted uppercase tracking-wider mb-2">Wheelbase</p>
        <p class="text-sm font-semibold text-track-muted flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-track-border inline-block"></span>
            Not set
        </p>
        <p class="text-xs text-track-muted mt-1 font-mono">—</p>
    </div>
    <div class="bg-track-card border border-track-border rounded-xl p-4">
        <p class="text-xs text-track-muted uppercase tracking-wider mb-2">Active Profile</p>
        <p class="text-sm font-semibold text-track-muted flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-track-border inline-block"></span>
            None loaded
        </p>
        <p class="text-xs text-track-muted mt-1 font-mono">—</p>
    </div>
    <div class="bg-track-card border border-track-border rounded-xl p-4">
        <p class="text-xs text-track-muted uppercase tracking-wider mb-2">Connected Devices</p>
        <p class="text-sm font-semibold text-racing-blue flex items-center gap-2">
            <span class="w-2 h-2 rounded-full bg-racing-blue inline-block"></span>
            0 detected
        </p>
        <p class="text-xs text-track-muted mt-1 font-mono">Polling…</p>
    </div>
</div>

<!-- Quick actions -->
<div class="mb-8">
    <h2 class="text-sm font-semibold text-track-muted uppercase tracking-widest mb-4">Quick Actions</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        <a href="map-wheel"
           class="group flex flex-col gap-3 bg-track-card border border-track-border hover:border-racing-orange rounded-xl p-5 transition-colors cursor-pointer">
            <div class="w-10 h-10 rounded-lg bg-racing-orange/10 flex items-center justify-center group-hover:bg-racing-orange/20 transition-colors">
                <svg class="w-5 h-5 text-racing-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-track-bright">Map Wheel</p>
                <p class="text-xs text-track-muted mt-0.5">Step-by-step controller mapping wizard</p>
            </div>
        </a>

        <a href="devices"
           class="group flex flex-col gap-3 bg-track-card border border-track-border hover:border-racing-blue rounded-xl p-5 transition-colors cursor-pointer">
            <div class="w-10 h-10 rounded-lg bg-racing-blue/10 flex items-center justify-center group-hover:bg-racing-blue/20 transition-colors">
                <svg class="w-5 h-5 text-racing-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 3H5a2 2 0 00-2 2v4m6-6h10a2 2 0 012 2v4M9 3v18m0 0h10a2 2 0 002-2V9M9 21H5a2 2 0 01-2-2V9m0 0h18" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-track-bright">Devices</p>
                <p class="text-xs text-track-muted mt-0.5">View and configure connected controllers</p>
            </div>
        </a>

        <a href="generate"
           class="group flex flex-col gap-3 bg-track-card border border-track-border hover:border-racing-green rounded-xl p-5 transition-colors cursor-pointer">
            <div class="w-10 h-10 rounded-lg bg-racing-green/10 flex items-center justify-center group-hover:bg-racing-green/20 transition-colors">
                <svg class="w-5 h-5 text-racing-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-track-bright">Generate &amp; Install</p>
                <p class="text-xs text-track-muted mt-0.5">Build and deploy your mapping profile</p>
            </div>
        </a>
    </div>
</div>

<!-- Race stripe decoration -->
<div class="flex gap-1 opacity-20 mt-12">
    @for (int i = 0; i < 24; i++)
    {
        <div class="h-1 flex-1 rounded-full @(i % 2 == 0 ? "bg-racing-orange" : "bg-track-border")"></div>
    }
</div>
