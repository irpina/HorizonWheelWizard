@page "/map-wheel"
<PageTitle>Map Wheel — Horizon SimTool</PageTitle>

<div class="mb-6">
    <h1 class="text-2xl font-bold text-track-bright tracking-tight">Map Wheel</h1>
    <p class="text-sm text-track-muted mt-1">Step-by-step controller mapping wizard</p>
</div>

<div class="max-w-2xl">
    <!-- Device selector -->
    <div class="bg-track-card border border-track-border rounded-xl p-5 mb-4">
        <label class="block text-xs font-semibold text-track-muted uppercase tracking-wider mb-2">Select Device</label>
        <div class="flex gap-3">
            <select class="flex-1 bg-track-surface border border-track-border text-track-text text-sm rounded-lg px-3 py-2 focus:outline-none focus:border-racing-orange">
                <option>— No devices detected —</option>
            </select>
            <button class="px-4 py-2 bg-racing-orange hover:bg-racing-orange/90 text-white text-sm font-semibold rounded-lg transition-colors">
                Start Mapping
            </button>
        </div>
    </div>

    <!-- Wizard placeholder -->
    <div class="bg-track-card border border-track-border rounded-xl p-8 text-center">
        <div class="w-16 h-16 rounded-full bg-racing-orange/10 flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-racing-orange" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
            </svg>
        </div>
        <h2 class="text-lg font-semibold text-track-bright mb-2">Ready to Map</h2>
        <p class="text-sm text-track-muted max-w-sm mx-auto">
            Connect your wheel base and pedals, select the device above, then click <strong class="text-track-text">Start Mapping</strong> to begin the 26-step wizard.
        </p>
        <div class="mt-6 grid grid-cols-3 gap-3 text-xs text-track-muted">
            <div class="bg-track-surface rounded-lg p-3">
                <p class="text-racing-orange font-semibold text-base mb-1">26</p>
                <p>Mapping steps</p>
            </div>
            <div class="bg-track-surface rounded-lg p-3">
                <p class="text-racing-blue font-semibold text-base mb-1">All</p>
                <p>Devices polled</p>
            </div>
            <div class="bg-track-surface rounded-lg p-3">
                <p class="text-racing-green font-semibold text-base mb-1">XML</p>
                <p>Profile output</p>
            </div>
        </div>
    </div>
</div>
