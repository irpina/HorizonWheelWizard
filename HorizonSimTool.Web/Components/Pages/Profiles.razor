@page "/profiles"
<PageTitle>Profiles — Horizon SimTool</PageTitle>

<div class="mb-6 flex items-center justify-between">
    <div>
        <h1 class="text-2xl font-bold text-track-bright tracking-tight">Profiles</h1>
        <p class="text-sm text-track-muted mt-1">XML input mapping profiles from your game zip</p>
    </div>
</div>

<div class="bg-track-card border border-track-border rounded-xl p-6 text-center max-w-lg">
    <svg class="w-10 h-10 text-track-muted mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
    </svg>
    <p class="text-sm text-track-muted">No <code class="font-mono text-xs bg-track-surface px-1 py-0.5 rounded">inputmappingprofiles.zip</code> loaded.</p>
    <p class="text-xs text-track-muted mt-1">Locate your game install on the Generate page first.</p>
</div>
